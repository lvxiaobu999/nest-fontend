APP_NAME=nest-fontend

# 开发环境请参考 .env.development
# 生产环境请参考 .env.production

NODE_ENV=development
PORT=3000
COMPOSE_PROJECT_NAME=nest-frontend-dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nest_prisma_dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nest_prisma_dev?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=2h
LOG_LEVEL=debug
