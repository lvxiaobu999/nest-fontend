NODE_ENV=production
APP_NAME=nest-fontend
PORT=3001
COMPOSE_PROJECT_NAME=nest-frontend-prod
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nest_prisma_prod
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/nest_prisma_prod?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=prod-jwt-secret-change-me
JWT_EXPIRES_IN=2h
LOG_LEVEL=info # 日志级别，生产环境通常设置为 info
